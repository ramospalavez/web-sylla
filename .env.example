## Copiá este archivo a .env y cambiá los valores antes de publicar el sitio online.

# Usuario y contraseña para entrar a /admin
ADMIN_USER=admin
ADMIN_PASSWORD=cambiaEstaClave123

# Frase secreta para firmar la sesion (poné cualquier texto largo y random)
SESSION_SECRET=cambiaEsteSecretoPorAlgoLargoYUnico

# Código secreto para previsualizar el sitio real cuando está en modo construcción
# (URL: /admin/preview-ESTECODIGO, requiere además estar logueado en /admin)
PREVIEW_CODE=cambiaEsteCodigoPorAlgoDificilDeAdivinar

# Puerto donde corre el servidor
PORT=3000
